{
  "id": "/",
  "name": "Muskan's Maths",
  "short_name": "Maths",
  "description": "Premium Mathematics Learning Platform for Class 9 students featuring interactive chapters, formulas, solved examples, practice questions, quizzes, progress tracking, offline learning and regular content updates.",

  "lang": "en-IN",
  "dir": "ltr",

  "start_url": "/index.html?utm_source=pwa",
  "scope": "/",

  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],

  "orientation": "portrait-primary",

  "theme_color": "#FF4D6D",
  "background_color": "#FFF0F3",

