{
  "id": "/",
  "name": "Muskaan's Maths",
  "short_name": "Maths",
  "description": "Premium Mathematics Learning Platform for Class 9 students featuring interactive chapters, formulas, solved examples, practice questions, quizzes, progress tracking, offline learning and regular content updates.",

  "lang": "en-IN",
  "dir": "ltr",

  "start_url": "/index.html?utm_source=pwa",
  "scope": "/",

  "display": "standalone",
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui",
    "browser"
  ],

  "orientation": "portrait-primary",

  "theme_color": "#FF4D6D",
  "background_color": "#FFF0F3",

  "categories": [
    "education",
    "books",
    "reference",
    "productivity"
  ],

  "prefer_related_applications": false,

  "launch_handler": {
    "client_mode": [
      "focus-existing",
      "navigate-existing"
    ]
  },

  "icons": [
    {
      "src": "logo192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "logo512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    }
  ],

  "shortcuts": [
    {
      "name": "Study Chapters",
      "short_name": "Chapters",
      "description": "Browse all chapters",
      "url": "/index.html#chapters"
    },
    {
      "name": "Formula Vault",
      "short_name": "Formula",
      "description": "Quick formulas",
      "url": "/index.html#formulas"
    },
    {
      "name": "Practice Questions",
      "short_name": "Practice",
      "description": "Solve questions",
      "url": "/index.html#practice"
    },
    {
      "name": "Mock Test",
      "short_name": "Mock",
      "description": "Start mock test",
      "url": "/index.html#mock"
    }
  ],

  "share_target": {
    "action": "/share",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "file_handlers": [
    {
      "action": "/",
      "accept": {
        "application/pdf": [
          ".pdf"
        ],
        "text/plain": [
          ".txt"
        ]
      }
    }
  ]
}